// Namche Kitchen data model.
// Uses PostgreSQL (local Postgres in dev; point DATABASE_URL at your prod
// Postgres — e.g. Neon/Supabase — for deployment). DATABASE_URL is set in .env.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (Supabase transaction pooler / pgbouncer) for the app.
  url       = env("DATABASE_URL")
  // Direct/session connection used for migrations (prisma db push/migrate).
  directUrl = env("DIRECT_URL")
}

/// A menu section, e.g. "Momo", "Shawarma", "Masala Tea & Drinks".
model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  tagline   String?
  sortOrder Int        @default(0)
  items     MenuItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

/// A single dish. `price` holds a simple numeric price; `priceLabel` holds
/// freeform pricing for items with variants (e.g. "Small $11 / Large $15").
model MenuItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float?
  priceLabel  String?
  imageUrl    String?
  options     String? // e.g. "Chicken / Veg"
  tags        String? // comma separated: halal, vegetarian, vegan, spicy, popular
  spiceLevel  Int      @default(0) // 0 = not spicy, 1-3 = mild to hot
  featured    Boolean  @default(false)
  available   Boolean  @default(true)
  sortOrder   Int      @default(0)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
}

/// Table reservation submitted from /reservations.
model Reservation {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  date      DateTime
  time      String
  partySize Int
  notes     String?
  status    String   @default("pending") // pending | confirmed | cancelled
  createdAt DateTime @default(now())
}

/// Catering enquiry submitted from /catering.
model CateringInquiry {
  id         String    @id @default(cuid())
  name       String
  email      String
  phone      String
  eventDate  DateTime?
  eventType  String?
  guestCount Int?
  message    String?
  status     String    @default("new") // new | contacted | booked | closed
  createdAt  DateTime  @default(now())
}

/// Newsletter / "join the table" email capture from the public site.
model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String? // where they signed up, e.g. "footer"
  createdAt DateTime @default(now())
}

/// Admin login. Seeded from ADMIN_EMAIL / ADMIN_PASSWORD.
model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
}
