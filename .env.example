# Copy to .env.local (local dev) and set the same vars in your Vercel project
# (Project → Settings → Environment Variables) for deployment.

# --- Database (PostgreSQL) ---------------------------------------------------
# Local dev: your local Postgres.
#   DATABASE_URL / DIRECT_URL = postgresql://USER:PASSWORD@localhost:5432/namche_kitchen
# Production on Vercel (Supabase): use the pooled URL for DATABASE_URL and the
# session/direct URL for DIRECT_URL (migrations). Copy them from
# Supabase → Connect → ORMs → Prisma. URL-encode special chars in the password.
DATABASE_URL="postgresql://postgres.<ref>:<DB_PASSWORD>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<DB_PASSWORD>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# --- Admin auth (seeded by `prisma db seed`) --------------------------------
ADMIN_EMAIL="admin@namchekitchen.ca"
ADMIN_PASSWORD="change-me"
# Long random string used to sign the admin session cookie.
AUTH_SECRET="generate-a-long-random-string"

# --- Public site config -----------------------------------------------------
NEXT_PUBLIC_ORDER_URL="https://online.namchekitchen.ca"
NEXT_PUBLIC_SITE_NAME="Namche Kitchen"

# --- Chatbot assistant via OpenRouter (server-side only) --------------------
# Get a key at https://openrouter.ai/keys — do NOT prefix with NEXT_PUBLIC.
OPENROUTER_API_KEY="sk-or-v1-..."
OPENROUTER_MODEL="openai/gpt-4o-mini"

# --- Supabase client keys (public) ------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
